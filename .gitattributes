# Force LF line endings for shell scripts and config files
*.sh        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.env*      text eol=lf
