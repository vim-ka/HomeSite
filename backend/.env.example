APP_ENV=production
DEBUG=false
DATABASE_URL=sqlite+aiosqlite:////opt/homesite/data/homesite.db
JWT_SECRET_KEY=CHANGE-ME-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DEVICE_GATEWAY_URL=http://localhost:8001
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
GATEWAY_API_PORT=8001
INTERNAL_API_SECRET=CHANGE-ME-internal-secret
CORS_ORIGINS=https://homesite.local
RATE_LIMIT_DEFAULT=60/minute
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/opt/homesite/logs/backend.log   # uncomment to enable file rotation
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5
