# Application
APP_ENV=prod
DEBUG=false

# Database (SQLite default, PostgreSQL optional)
DATABASE_URL=sqlite+aiosqlite:///./sensors.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/homesite

# JWT
JWT_SECRET_KEY=CHANGE-ME-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Device Gateway
DEVICE_GATEWAY_URL=http://localhost:8001
# MQTT settings are configured via UI (stored in config_kv database)

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Device Gateway internal
GATEWAY_API_PORT=8001
GATEWAY_DEBOUNCE_SECONDS=5.0

# Internal communication secret (backend <-> device gateway)
INTERNAL_API_SECRET=CHANGE-ME-internal-secret

# Rate limiting
RATE_LIMIT_DEFAULT=60/minute

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
